          "type": "string",
          "minLength": 1
        },
        "line2": {
          "type": "string",
          "minLength": 1
        },
        "postTown": {
          "type": "string",
          "minLength": 1
        },
        "county": {
          "type": "string",
          "minLength": 1
        },
        "postCode": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "directions": {
      "type": "string",
      "minLength": 1
    },
    "logoUrl": {
