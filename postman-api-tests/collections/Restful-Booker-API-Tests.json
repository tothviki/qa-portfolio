{
  "info": {
    "name": "Restful-Booker API Tests",
    "description": "Complete API test suite for Restful-Booker - Portfolio project",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "portfolio-001"
