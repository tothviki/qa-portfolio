                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/booking/999999999",
              "host": ["{{baseUrl}}"],
              "path": ["booking", "999999999"]
            }
          }
