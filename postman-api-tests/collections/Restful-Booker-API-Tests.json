  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "POST /api/auth/login should create token with valid credentials",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains token', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('token');",
                  "  pm.expect(body.token).to.be.a('string');",
                  "  pm.expect(body.token.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.environment.set('authToken', pm.response.json().token);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/login should reject invalid credentials",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"wrong-password\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401', () => {",
                  "  pm.response.to.have.status(401);",
                  "});",
                  "",
                  "pm.test('Response contains invalid credentials error', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.error).to.eql('Invalid credentials');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Booking API",
      "item": [
        {
          "name": "POST /api/booking should create booking with valid data",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roomid\": 1,\n  \"firstname\": \"John\",\n  \"lastname\": \"Smith\",\n  \"depositpaid\": true,\n  \"email\": \"john.smith@example.com\",\n  \"phone\": \"07123456789\",\n  \"bookingdates\": {\n    \"checkin\": \"2028-01-10\",\n    \"checkout\": \"2028-01-12\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/booking",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "booking"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', () => {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contains bookingid', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('bookingid');",
                  "  pm.expect(body.bookingid).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('Booking data is correct', () => {",
                  "  const body = pm.response.json();",
                  "  const requestBody = JSON.parse(pm.request.body.raw);",
                  "  pm.expect(body.firstname).to.eql(requestBody.firstname);",
                  "  pm.expect(body.lastname).to.eql(requestBody.lastname);",
                  "  pm.expect(body.roomid).to.eql(requestBody.roomid);",
                  "  pm.expect(body.depositpaid).to.eql(requestBody.depositpaid);",
                  "  pm.expect(body.bookingdates.checkin).to.eql(requestBody.bookingdates.checkin);",
                  "  pm.expect(body.bookingdates.checkout).to.eql(requestBody.bookingdates.checkout);",
                  "});",
                  "",
                  "pm.environment.set('bookingId', pm.response.json().bookingid);"
                ]
              }
            }
          ]
        },
