  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Generate Auth Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test: Verify successful authentication",
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Test: Response contains token",
                  "pm.test('Response contains token', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property('token');",
                  "    pm.expect(response.token).to.be.a('string');",
                  "});",
                  "",
                  "// Save token to environment variable",
                  "const token = pm.response.json().token;",
                  "pm.environment.set('authToken', token);",
                  "console.log('Token saved: ' + token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth",
              "host": ["{{baseUrl}}"],
              "path": ["auth"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Create Booking (POST)",
      "item": [
        {
          "name": "Create booking with valid data",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test: Status code is 200 (API returns 200 for successful creation)",
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Test: Response has bookingid",
                  "pm.test('Response contains bookingid', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property('bookingid');",
                  "    pm.expect(response.bookingid).to.be.a('number');",
                  "});",
                  "",
                  "// Test: Booking data matches request",
                  "pm.test('Booking data is correct', () => {",
                  "    const response = pm.response.json();",
                  "    const requestBody = JSON.parse(pm.request.body.raw);",
                  "    pm.expect(response.booking.firstname).to.eql(requestBody.firstname);",
                  "    pm.expect(response.booking.lastname).to.eql(requestBody.lastname);",
                  "    pm.expect(response.booking.totalprice).to.eql(requestBody.totalprice);",
                  "    pm.expect(response.booking.depositpaid).to.eql(requestBody.depositpaid);",
                  "    pm.expect(response.booking.bookingdates.checkin).to.eql(requestBody.bookingdates.checkin);",
                  "    pm.expect(response.booking.bookingdates.checkout).to.eql(requestBody.bookingdates.checkout);",
                  "});",
                  "",
                  "// Save booking ID for subsequent tests",
                  "const bookingId = pm.response.json().bookingid;",
                  "pm.environment.set('bookingId', bookingId);",
                  "console.log('Created booking with ID: ' + bookingId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"firstname\": \"John\",\n    \"lastname\": \"Doe\",\n    \"totalprice\": 150,\n    \"depositpaid\": true,\n    \"bookingdates\": {\n        \"checkin\": \"2024-12-25\",\n        \"checkout\": \"2025-01-05\"\n    },\n    \"additionalneeds\": \"Breakfast\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/booking",
              "host": ["{{baseUrl}}"],
              "path": ["booking"]
            }
          }
        },
