    {
      "name": "4. Update Booking (PUT)",
      "item": [
        {
          "name": "Full update existing booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test: Status is 200",
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Test: Booking updated successfully",
                  "pm.test('Booking data updated correctly', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.firstname).to.eql('UpdatedName');",
                  "    pm.expect(response.lastname).to.eql('UpdatedSurname');",
                  "    pm.expect(response.totalprice).to.eql(500);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Cookie",
                "value": "token={{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"firstname\": \"UpdatedName\",\n    \"lastname\": \"UpdatedSurname\",\n    \"totalprice\": 500,\n    \"depositpaid\": false,\n    \"bookingdates\": {\n        \"checkin\": \"2025-01-01\",\n        \"checkout\": \"2025-01-10\"\n    },\n    \"additionalneeds\": \"Lunch\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/booking/{{bookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["booking", "{{bookingId}}"]
            }
          }
        },
